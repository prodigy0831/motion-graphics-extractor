# Python 가상환경
venv/
venv_sam2/

# 외부 라이브러리 (서브모듈 대신 .gitignore로 제외)
external/

# 모델 파일 (용량 큼)
models/

# 입력 영상 (클라이언트 자료 보안)
input/*
!input/.gitkeep

# 추출 결과물 (클라이언트 자료 보안)
output/*
!output/.gitkeep

# Python 캐시
__pycache__/
*.pyc

# macOS
.DS_Store

# VSCode 개인 설정
.vscode/

# Claude Code 로컬 설정
.claude/

# GUI (Electron)
gui/node_modules/
gui/dist/
